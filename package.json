{
  "name": "teleMirror",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.telemirror.app",
    "productName": "teleMirror",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "zip",
      "icon": "assets/teleMirror.png"
    }
  }
}
